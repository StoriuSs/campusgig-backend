{
  "name": "campusgig-backend",
  "version": "1.0.0",
  "description": "Backend for CampusGig platform",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "nest start --watch",
    "docker:dev": "docker compose --env-file .env.development -f docker-compose.dev.yaml up -d --build",
    "docker:prod": "docker compose --env-file .env.production -f docker-compose.prod.yaml up -d --build",
    "docker:down": "docker compose -f docker-compose.dev.yaml -f docker-compose.prod.yaml down",
    "docker:reset": "docker compose -f docker-compose.dev.yaml -f docker-compose.prod.yaml down -v",
    "docker:logs": "docker logs campusgig-app-dev -f",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prisma:generate": "dotenv -e .env.development -- prisma generate",
    "prisma:migrate": "dotenv -e .env.development -- prisma migrate dev",
    "prisma:migrate:prod": "dotenv -e .env.production -- prisma migrate deploy",
    "prisma:studio": "dotenv -e .env.development -- prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:reset": "prisma migrate reset",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.config.js",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.943.0",
    "@bull-board/api": "^6.20.2",
    "@bull-board/express": "^6.20.2",
    "@bull-board/nestjs": "^6.20.2",
    "@keycloak/keycloak-admin-client": "^26.5.4",
    "@keyv/redis": "^5.1.3",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^2.2.2",
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/throttler": "^6.2.1",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "axios": "^1.13.2",
    "bullmq": "^5.70.1",
    "cache-manager": "^5.7.6",
    "cacheable": "^2.3.1",
    "camelcase-keys": "^10.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "express-basic-auth": "^1.2.1",
    "handlebars": "^4.7.8",
    "helmet": "^8.0.0",
    "joi": "^18.0.1",
    "jose": "^6.1.3",
    "keyv": "^5.5.3",
    "multer": "^2.0.2",
    "nestjs-pino": "^4.5.0",
    "nodemailer": "^6.9.15",
    "pg": "^8.18.0",
    "pino-http": "^10.5.0",
    "pino-loki": "^3.0.0",
    "prom-client": "^15.1.3",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "snakecase-keys": "^9.0.2",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.4",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/joi": "^17.2.2",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.7.5",
    "@types/nodemailer": "^6.4.16",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.16.0",
    "@types/react": "18.3.12",
    "@types/sharp": "^0.31.1",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@types/yamljs": "^0.2.34",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.7",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.3.3",
    "prisma": "^7.4.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-loader": "^9.5.4",
    "ts-morph": "^27.0.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.53.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
