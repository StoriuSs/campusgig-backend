<!-- Mirrors the keycloakify auth EmailLayout so all CampusGig mail shares one look. -->
<html lang='en'>
    <head>
        <meta charset='UTF-8' />
        <meta name='viewport' content='width=device-width, initial-scale=1.0' />
        <title>{{heading}}</title>
    </head>
    <body style="background-color:#FAF8F4;padding:40px 0;margin:0;font-family:'Inter','Segoe UI','Helvetica Neue',Roboto,Ubuntu,sans-serif;">
        <table role='presentation' width='100%' cellpadding='0' cellspacing='0' style='border-collapse:collapse;'>
            <tr>
                <td align='center'>
                    <table role='presentation' cellpadding='0' cellspacing='0' style="background-color:#FFFFFF;border:1px solid #E5E1D8;border-radius:16px;box-shadow:0 1px 2px 0 rgba(15,23,42,0.04);max-width:600px;width:100%;">
                        <tr>
                            <td style='padding:40px;'>
                                <!-- Brand wordmark — two-tone CampusGig -->
                                <div style='text-align:center;margin-bottom:32px;'>
                                    <span style="font-family:'Manrope','Inter',sans-serif;font-size:28px;font-weight:bold;letter-spacing:-0.5px;line-height:1;">
                                        <span style='color:#5B5BF5;'>Campus</span><span style='color:#64748B;'>Gig</span>
                                    </span>
                                </div>

                                <h1 style='font-size:20px;font-weight:bold;color:#0F172A;line-height:28px;margin:0 0 16px;'>{{heading}}</h1>
                                <p style='font-size:16px;line-height:24px;color:#475569;margin:0 0 24px;'>{{body}}</p>

                                {{#if ctaUrl}}
                                    <div style='text-align:center;margin:32px 0;'>
                                        <a href='{{ctaUrl}}' style="background-color:#5B5BF5;border-radius:999px;color:#FFFFFF;font-size:15px;font-weight:bold;text-decoration:none;display:inline-block;padding:12px 28px;">{{ctaLabel}}</a>
                                    </div>
                                {{/if}}

                                <hr style='border:none;border-top:1px solid #E5E1D8;margin:32px 0;' />

                                <div style='text-align:center;'>
                                    <p style='font-size:14px;line-height:24px;color:#475569;margin:0;'>&copy; {{year}} {{appName}} &mdash; All rights reserved</p>
                                    <p style='font-size:12px;line-height:20px;color:#94A3B8;margin:8px 0 0;'>This is an automated email, please do not reply.</p>
                                </div>
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    </body>
</html>
