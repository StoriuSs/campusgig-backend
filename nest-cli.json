{
    "collection": "@nestjs/schematics",
    "sourceRoot": "src",
    "compilerOptions": {
        "deleteOutDir": true,
        "webpack": false,
        "tsConfigPath": "tsconfig.build.json",
        "assets": [{ "include": "shared/infrastructure/email/templates/**/*", "outDir": "dist/src" }],
        "watchAssets": true,
        "plugins": [
            {
                "name": "@nestjs/swagger",
                "options": {
                    "introspectComments": true,
                    "classValidatorShim": true,
                    "dtoFileNameSuffix": [".dto.ts", ".request.dto.ts", ".response.dto.ts"]
                }
            }
        ]
    }
}
