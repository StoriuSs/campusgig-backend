          "noValue": "0"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Requests" },
            "properties": [{ "id": "unit", "value": "short" }, { "id": "decimals", "value": 0 }]
          },
          {
            "matcher": { "id": "byName", "options": "4xx" },
            "properties": [
