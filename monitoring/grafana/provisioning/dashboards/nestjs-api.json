        "cellHeight": "sm",
        "footer": { "enablePagination": true },
        "sortBy": [{ "desc": true, "displayName": "Requests" }]
      },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total[$__range])) by (method, path)",
          "format": "table",
          "instant": true,
          "refId": "requests"
        },
        {
          "expr": "sum(increase(http_requests_total{status_code=~\"4..\"}[$__range])) by (method, path)",
          "format": "table",
          "instant": true,
          "refId": "errors4xx"
        },
        {
          "expr": "sum(increase(http_requests_total{status_code=~\"5..\"}[$__range])) by (method, path)",
          "format": "table",
          "instant": true,
          "refId": "errors5xx"
        },
        {
          "expr": "sum(rate(http_request_duration_seconds_sum[$__range])) by (method, path) / sum(rate(http_request_duration_seconds_count[$__range])) by (method, path) * 1000",
          "format": "table",
          "instant": true,
          "refId": "latency"
        }
      ],
      "title": "Endpoint Details",
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "method": "Method",
              "path": "Path",
              "Value #requests": "Requests",
              "Value #errors4xx": "4xx",
              "Value #errors5xx": "5xx",
              "Value #latency": "Avg Latency"
            }
          }
        }
      ],
      "type": "table"
    },
