// Snapshot fields (`gig*Snapshot`) are populated at place time so edits to the gig
// don't break existing orders. `id` is the routing handle; user-facing code is
// `'CG-' + number.padStart(4)`. Deadlines are nullable until the prior step sets
// them. All status transitions use Prisma $transactions with a status guard.

enum OrderStatus {
  PendingReview
  InProgress
  Late
  Delivered
  AwaitingFinalization
  Completed
  Cancelled
  Frozen // reserved for F11 (Disputes)
}

model Order {
  id     String @id @default(uuid())
  number Int    @unique @default(autoincrement())

  buyerId  String
  sellerId String
  gigId    String

  gigTitleSnapshot    String
  gigPriceVndSnapshot Int
  gigDeliveryDays     Int
  gigCoverKey         String?

  status OrderStatus @default(PendingReview)

  placedAt        DateTime  @default(now()) @db.Timestamptz(6)
  acceptedAt      DateTime? @db.Timestamptz(6)
  deliveredAt     DateTime? @db.Timestamptz(6)
  completedAt     DateTime? @db.Timestamptz(6)
  cancelledAt     DateTime? @db.Timestamptz(6)
  autoCompletedAt DateTime? @db.Timestamptz(6)

  // Deadlines — exact-hour countdowns from event timestamps
  acceptDeadline   DateTime? @db.Timestamptz(6) // placedAt + 24h
  deliveryDeadline DateTime? @db.Timestamptz(6) // acceptedAt + gigDeliveryDays × 24h
  reviewDeadline   DateTime? @db.Timestamptz(6) // deliveredAt + 72h
  disputeDeadline  DateTime? @db.Timestamptz(6) // autoCompletedAt + 7×24h

  cancelledByUserId  String?
  cancellationReason String?

  buyer         User           @relation("OrderBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller        User           @relation("OrderSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  gig           Gig            @relation(fields: [gigId], references: [id])
  events        OrderEvent[]
  deliveries    Delivery[]
  extensions    Extension[]
  cancellations Cancellation[]
  review        Review?
  dispute       Dispute?

  @@index([buyerId, status, placedAt(sort: Desc)])
  @@index([sellerId, status, placedAt(sort: Desc)])
  // Defensive sweep indexes — BullMQ re-derive if the queue is dropped.
  @@index([status, acceptDeadline])
  @@index([status, deliveryDeadline])
  @@index([status, reviewDeadline])
  @@index([status, disputeDeadline])
}
