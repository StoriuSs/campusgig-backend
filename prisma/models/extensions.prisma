// Feature 09 / 10 — Delivery / review extension requests.
//
// Sent only by the seller. Allowed during `InProgress` (extends
// `Order.deliveryDeadline`) AND during `Delivered` (extends
// `Order.reviewDeadline` — buyer's review window). Order status pill stays
// the same while the request is Pending — only the deadline countdown
// changes on Accept.
//
// At most ONE Pending extension per order at a time — enforced via repo
// guard, not a DB unique index (because past Pending → terminal rows must
// remain queryable for history).
//
// 24h expiry — a `ExtensionExpiryJob` (BullMQ delayed job) marks the row
// `Expired` if no decision by `expiresAt`. Same idempotent guard pattern
// as the order-deadline jobs.

enum ExtensionStatus {
  Pending
  Accepted
  Rejected
  Expired
}

model Extension {
  id             String          @id @default(uuid())
  orderId        String
  requestedById  String // always the seller in v1
  hoursRequested Int // matches one of the M1 radio presets (12/24/48/72 hours)
  reason         String? // optional free text — chat carries the followup conversation
  status         ExtensionStatus @default(Pending)
  expiresAt      DateTime        @db.Timestamptz(6) // requestedAt + 24h
  requestedAt    DateTime        @default(now()) @db.Timestamptz(6)
  decidedAt      DateTime?       @db.Timestamptz(6)
  decidedById    String? // buyer who decided

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, status])
}
