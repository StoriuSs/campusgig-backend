model User {
  id         String @id @default(uuid())
  keycloakId String @unique // Links to Keycloak user (token.sub)

  username       String? @unique
  email          String? // Not unique intentionally — soft-delete flow; Keycloak deduplicates active accounts.
  displayName    String?
  avatarUrl      String? // Stores the S3 OBJECT KEY, not a URL. Controller resolves to a presigned GET URL on read. Field name is legacy from the boilerplate; rename to avatarKey is a post-MVP cleanup.
  bio            String?
  hasSetUsername Boolean @default(false)
  // emailVerified Boolean  @default(false)
  // lastSyncedAt  DateTime? @db.Timestamptz(6)

  location  String?
  roleLine  String?
  languages String?

  // Endorsed-badge fields — admin grant/revoke wired in F14.
  endorsedAt DateTime? @db.Timestamptz(6)
  endorsedBy String? // Admin user ID; FK enforcement deferred until admin role exists.

  // F14 — free-text admin note kept on the user (Admin / User Detail modal).
  adminNote String?

  // Set by JIT provisioner on JWT `admin` realm role. Filter buyer/seller queries with isAdmin=false.
  isAdmin Boolean @default(false)

  // F11 rating aggregate (per-seller, across all gigs). Increment-only; reviews are write-once.
  // avg (1-5) = ratingSumHalfStars / 2 / reviewCount; reviewCount 0 = "New seller".
  reviewCount        Int @default(0)
  ratingSumHalfStars Int @default(0)

  // Wallet (Feature 07) — all VND, integer-only. walletBalance is the withdrawable
  // amount. pendingWithdrawalBalance holds money requested but not yet processed
  // by an admin. escrowBalance holds money for active outgoing orders (buyer side;
  // populated by F09–10). Invariant: balance + pending + escrow conserved across
  // all operations.
  walletBalance            Int @default(0)
  escrowBalance            Int @default(0)
  pendingWithdrawalBalance Int @default(0)

  // Set on first withdrawal; editable but blocked while a Pending withdrawal exists. One account per user in v1.
  bankName          String?
  bankAccountNumber String?
  bankAccountHolder String?

  // F17 email preferences: master + per-category. Default true keeps F15's
  // send-everything; in-app notifications are never gated by these.
  emailNotificationsEnabled Boolean @default(true)
  emailOrders               Boolean @default(true)
  emailDisputes             Boolean @default(true)
  emailGigs                 Boolean @default(true)

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)
  deletedBy String?

  skills         UserSkill[]
  portfolioItems PortfolioItem[]
  savedGigs      SavedGig[]
  transactions         Transaction[]
  withdrawalRequests   WithdrawalRequest[] @relation("WithdrawalRequester")
  processedWithdrawals WithdrawalRequest[] @relation("WithdrawalProcessor")

  // Updated on last socket disconnect; null if never connected. Falls back to "Last seen <ago>" when offline.
  lastSeenAt DateTime? @db.Timestamptz(6)

  sentMessages         Message[]           @relation("MessageSender")
  threadParticipationA MessageThread[]     @relation("ThreadUserA")
  threadParticipationB MessageThread[]     @relation("ThreadUserB")
  messageReadCursors   MessageReadCursor[]
  ordersAsBuyer  Order[] @relation("OrderBuyer")
  ordersAsSeller Order[] @relation("OrderSeller")
  sellerReviews  Review[] @relation("SellerReviews")
  buyerReviews   Review[] @relation("BuyerReviews")
  filedDisputes    Dispute[] @relation("DisputeFiler")
  resolvedDisputes Dispute[] @relation("DisputeResolver")
  adminActivityLogs AdminActivityLog[] @relation("AdminActivityActor")
  reportExports     ReportExport[]     @relation("ReportExporter")
  notifications     Notification[]     @relation("UserNotifications")

  @@index([keycloakId])
  @@index([username])
  // @@index([email])
  @@index([keycloakId, deletedAt])
  @@index([deletedAt])
  @@index([isAdmin])
}

// User's listed skills (free-form tags). Owned by User; cascade on delete.
// Modeled as a table (not a TEXT[] column) so future features can search/filter
// users by skill without needing GIN-indexing. See specs/00-database-schema.spec.md.
model UserSkill {
  id        String   @id @default(uuid())
  userId    String
  name      String
  position  Int // 0-based display order; drag-reorder is a future feature.
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// User's portfolio images. Owned by User; cascade on delete.
// Each item is an S3 object key (resolved to presigned URL by controller on read).
model PortfolioItem {
  id        String   @id @default(uuid())
  userId    String
  imageKey  String // S3 object key, same pattern as User.avatarUrl
  width     Int // Stored after server-side image processing (max 1600 wide)
  height    Int // Stored after server-side image processing (max 1200 tall)
  position  Int // 0-based display order. Newest first by default in v1.
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
