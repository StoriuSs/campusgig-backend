# Dependencies
node_modules/
dist/
build/

# Environment
# Only .env.example is committed. Copy it to create:
#   .env.development  — for local dev
#   .env.production   — for VPS (fill in real values)
.env.development
.env.production
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.pnpm-store/
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Uploads
uploads/
!uploads/.gitkeep

# Testing
coverage/
.nyc_output/

# Prisma
# Uncomment if you want to ignore migrations in git
# prisma/migrations/
/generated

# Temp files
*.tmp
*.temp

# Database dumps — pg_dump output from "Refreshing local dev from prod"
# (see docs/vps-operator-cheatsheet.md). These contain real prod user data
# and MUST NEVER be committed. The negation re-allows Prisma migration .sql
# files since those are part of the schema history.
*.sql
*.dump
!prisma/migrations/**/*.sql

# Agents
.agents

/AI-DEV-TASKS
/docs

