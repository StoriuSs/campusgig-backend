# ==============================================================================
# Environment Configuration Template
#
# Copy this file to .env.development or .env.production and fill in your values:
#
#   cp .env.example .env.development   # local development
#   cp .env.example .env.production    # production (VPS)
#
# Both .env.development and .env.production are gitignored.
# Only this file (.env.example) is committed to git.
# ==============================================================================

# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
APP_NAME=YourAppName
BASE_URL=http://localhost:3000
# Frontend origin for deep-links in notification emails (CTA buttons).
FRONTEND_URL=http://localhost:3001
GRACEFUL_SHUTDOWN_TIMEOUT_MS=5000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname?schema=public
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_db_name
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# Cache (2-Layer: In-memory + Redis)
CACHE_TTL=3600
CACHE_LRU_SIZE=500

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_TTL=3600

# Request timeout (in ms)
REQUEST_TIMEOUT_MS=30000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Email (optional — uncomment to enable)
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=
# EMAIL_PASSWORD=
# EMAIL_FROM_NAME=YourAppName
# EMAIL_FROM_ADDRESS=noreply@example.com

# File Upload
STORAGE_TYPE=local  # options: local, s3
UPLOAD_DEST=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# AWS S3 (if STORAGE_TYPE=s3)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=

# Logging
LOG_LEVEL=info  # debug | info | warn | error
LOG_DIR=./logs

# Keycloak
KEYCLOAK_HOST=localhost
KEYCLOAK_PORT=8080
KEYCLOAK_HOSTNAME=localhost
# Public URL used for JWT issuer validation (what the browser sees)
KEYCLOAK_PUBLIC_URL=http://localhost:8080
KEYCLOAK_REALM=your-realm
KEYCLOAK_CLIENT_ID=your-client-id
KEYCLOAK_CLIENT_SECRET=your-client-secret
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_DB_NAME=keycloak

# Prometheus & Grafana (Monitoring)
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin

# Loki (Log Aggregation)
LOKI_PORT=3100
LOKI_HOST=http://localhost:3100
LOKI_ENABLED=true

# Bull Board
BULL_BOARD_USER=admin
BULL_BOARD_PASSWORD=admin
